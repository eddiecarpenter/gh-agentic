{
  "description": "Schema for `gh agentic status features --json`. The envelope is identical in shape to requirements_list but with Feature items.",
  "envelope": {
    "items": "array-of-object",
    "totals": "object"
  },
  "totals_fields": {
    "open": "number",
    "blocked": "number"
  },
  "item_fields": {
    "number": "number",
    "title": "string",
    "body": "string",
    "stage": "string",
    "created_at": "string",
    "last_transitioned_at": "string",
    "owning_repo": "string",
    "blocked": "object-or-null",
    "parent_requirement": "object-or-null",
    "tasks": "array",
    "branch": "object-or-null",
    "pr": "object-or-null"
  }
}
