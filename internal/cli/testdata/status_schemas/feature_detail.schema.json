{
  "description": "Schema for `gh agentic status feature <N> --json`. A single self-contained object mirroring the Feature struct.",
  "root_fields": {
    "number": "number",
    "title": "string",
    "body": "string",
    "stage": "string",
    "created_at": "string",
    "last_transitioned_at": "string",
    "owning_repo": "string",
    "blocked": "object-or-null",
    "parent_requirement": "object-or-null",
    "tasks": "array",
    "branch": "object-or-null",
    "pr": "object-or-null"
  },
  "task_fields": {
    "number": "number",
    "title": "string",
    "closed": "boolean"
  },
  "branch_fields_when_present": {
    "name": "string",
    "exists": "boolean",
    "merged": "boolean"
  },
  "pr_fields_when_present": {
    "number": "number",
    "state": "string",
    "reviewers": "array"
  },
  "parent_requirement_fields_when_present": {
    "number": "number",
    "title": "string",
    "stage": "string",
    "owning_repo": "string"
  }
}
